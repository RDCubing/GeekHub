<Page
    x:Name="pageRoot"
    x:Class="GeekHub.ProjectPage"
    DataContext="{Binding DefaultViewModel, RelativeSource={RelativeSource Self}}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GeekHub"
    xmlns:common="using:GeekHub.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- TODO: Delete this line if the key AppName is declared in App.xaml -->
        <x:String x:Key="AppName">Projects</x:String>
    </Page.Resources>

    <!--
        This grid acts as a root panel for the page that defines two rows:
        * Row 0 contains the back button and page title
        * Row 1 contains the rest of the page layout
    -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                <GradientStop Color="#661E3C72" Offset="0.0"/>
                <!-- deep blue (transparent) -->
                <GradientStop Color="#662A5298" Offset="0.25"/>
                <!-- blue -->
                <GradientStop Color="#666A11CB" Offset="0.5"/>
                <!-- purple -->
                <GradientStop Color="#662575FC" Offset="0.75"/>
                <!-- bright blue -->
                <GradientStop Color="#6600C6FF" Offset="1.0"/>
                <!-- cyan -->

            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Back button and page title -->
        <Grid Background="{Binding AccentBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="backButton" Margin="39,59,39,0" Command="{Binding NavigationHelper.GoBackCommand, ElementName=pageRoot}"
                        Style="{StaticResource NavigationBackButtonNormalStyle}"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="Back"
                        AutomationProperties.AutomationId="BackButton"
                        AutomationProperties.ItemType="Navigation Button"/>
            <TextBlock x:Name="pageTitle" Text="{StaticResource AppName}" Style="{StaticResource HeaderTextBlockStyle}" Grid.Column="1" 
                        IsHitTestVisible="false" TextWrapping="NoWrap" VerticalAlignment="Bottom" Margin="0,0,30,40"/>
        </Grid>

        <ScrollViewer
    Grid.Row="1"
    ZoomMode="Disabled"
    HorizontalScrollMode="Auto"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollMode="Disabled"
    VerticalScrollBarVisibility="Disabled">

            <Grid>
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="40">

                    <!-- LEFT SIDE (Hero + About) -->
                    <StackPanel Width="500" Margin="0,0,30,0">

                        <!-- HERO -->
                        <Grid Height="320" Margin="0,0,0,20">
                            <Image Source="{Binding LocalDetailImage}" Stretch="UniformToFill"/>
                            <Rectangle Fill="#66000000"/>
                            <StackPanel VerticalAlignment="Bottom" Margin="20">
                                <TextBlock Text="{Binding Title}"
                                   FontSize="40"
                                   FontWeight="Light"
                                   Foreground="White"/>
                                <TextBlock Text="{Binding Subtitle}"
                                   FontSize="18"
                                   Foreground="#DDFFFFFF"/>
                            </StackPanel>
                        </Grid>

                        <!-- ABOUT (NOW UNDER IMAGE) -->
                        <TextBlock Text="About this project"
                           FontSize="26"
                           FontWeight="Light"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Description}"
                           FontSize="16"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- ACTIONS -->
                    <StackPanel Margin="0,0,30,0">
                        <Button Content="Download"
                        Padding="20,10"
                        Margin="0,0,0,10"
                        Click="OpenProject_Click"/>

                        <Button Content="View Source"
                        Padding="20,10"
                        Click="ViewSource_Click"/>
                    </StackPanel>

                    <!-- DETAILS -->
                    <StackPanel Width="300">

                        <TextBlock Text="Details"
               FontSize="26"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,10"/>

                        <TextBlock Text="Version:" Foreground="#888"/>
                        <TextBlock Text="{Binding Version}" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Publisher:" Foreground="#888"/>
                        <TextBlock Text="{Binding Publisher}" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Platform:" Foreground="#888"/>
                        <TextBlock Text="Windows" Foreground="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Status:" Foreground="#888"/>
                        <TextBlock Text="Active Development" Foreground="#4CAF50"/>

                    </StackPanel>

                </StackPanel>
            </Grid>

        </ScrollViewer>
    </Grid>
</Page>
