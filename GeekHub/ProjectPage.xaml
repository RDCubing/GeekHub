<Page
    x:Name="pageRoot"
    x:Class="GeekHub.ProjectPage"
    DataContext="{Binding DefaultViewModel, RelativeSource={RelativeSource Self}}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GeekHub"
    xmlns:common="using:GeekHub.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- TODO: Delete this line if the key AppName is declared in App.xaml -->
        <x:String x:Key="AppName">Projects</x:String>
    </Page.Resources>

    <!--
        This grid acts as a root panel for the page that defines two rows:
        * Row 0 contains the back button and page title
        * Row 1 contains the rest of the page layout
    -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">

                <GradientStop Color="#FF141326" Offset="0.0"/>
                <!-- deep dark indigo -->

                <GradientStop Color="#FF2A1833" Offset="0.25"/>
                <!-- muted plum -->

                <GradientStop Color="#FF3E2238" Offset="0.5"/>
                <!-- soft wine -->

                <GradientStop Color="#FF5A2F36" Offset="0.75"/>
                <!-- dim copper -->

                <GradientStop Color="#FF7A4A3A" Offset="1.0"/>
                <!-- toned-down amber -->

            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Back button and page title -->
        <Grid Background="{Binding AccentBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="backButton" Margin="39,59,39,0" Command="{Binding NavigationHelper.GoBackCommand, ElementName=pageRoot}"
                        Style="{StaticResource NavigationBackButtonNormalStyle}"
                        VerticalAlignment="Top"
                        AutomationProperties.Name="Back"
                        AutomationProperties.AutomationId="BackButton"
                        AutomationProperties.ItemType="Navigation Button"/>
            <TextBlock x:Name="pageTitle"  Text="Projects" x:Uid="ProjectsPage" Style="{StaticResource HeaderTextBlockStyle}" Grid.Column="1" 
                        IsHitTestVisible="false" TextWrapping="NoWrap" VerticalAlignment="Bottom" Margin="0,0,30,40"/>
        </Grid>

        <ScrollViewer
    Grid.Row="1"
    ZoomMode="Disabled"
    HorizontalScrollMode="Auto"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollMode="Disabled"
    VerticalScrollBarVisibility="Disabled">

            <Grid>
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="50">

                    <!-- MAIN CONTENT (LARGE FOCUS) -->
                    <StackPanel Width="650" Margin="0,0,40,0">

                        <!-- HERO -->
                        <Grid Height="360" Margin="0,0,0,25">
                            <Image Source="{Binding LocalDetailImage}" Stretch="UniformToFill"/>
                            <Rectangle Fill="#66000000"/>

                            <StackPanel VerticalAlignment="Bottom" Margin="22">
                                <TextBlock Text="{Binding Title}"
                                   FontSize="48"
                                   FontWeight="Light"
                                   Foreground="White"/>

                                <TextBlock Text="{Binding Subtitle}"
                                   FontSize="22"
                                   Foreground="#DDFFFFFF"/>
                            </StackPanel>
                        </Grid>

                        <!-- ABOUT -->
                        <TextBlock Text="About this project"
                           FontSize="32"
                           x:Uid="AboutProject"
                           FontWeight="Light"
                           Foreground="White"
                           Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding Description}"
                           FontSize="12"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- SIDE PANEL (DETAILS + ACTIONS) -->
                    <StackPanel Width="320" VerticalAlignment="Top">

                        <Button Padding="26,14"
                        x:Uid="Download"
                        Margin="0,0,0,14"
                        Click="OpenProject_Click"/>

                        <Button x:Uid="Source"
                        Padding="26,14"
                        Margin="0,0,0,30"
                        Click="ViewSource_Click"/>

                        <TextBlock Text="Details"
                           FontSize="30"
                           FontWeight="Light"
                           Foreground="White"
                           Margin="0,0,0,15"
                           x:Uid="Details"/>

                        <TextBlock x:Uid="Version" Text="Version:" Foreground="#888"/>
                        <TextBlock Text="{Binding Version}" Foreground="#CCC" Margin="0,0,0,12"/>

                        <TextBlock x:Uid="Publisher" Text="Publisher:" Foreground="#888"/>
                        <TextBlock Text="{Binding Publisher}" Foreground="#CCC" Margin="0,0,0,12"/>

                        <TextBlock x:Uid="Platform" Text="Platform:" Foreground="#888"/>
                        <TextBlock Text="{Binding Framework}" Foreground="#CCC" Margin="0,0,0,12"/>

                        <TextBlock x:Uid="Status" Text="Status:" Foreground="#888"/>
                        <TextBlock Text="Active Development" Foreground="#4CAF50"/>

                    </StackPanel>

                </StackPanel>
            </Grid>

        </ScrollViewer>
    </Grid>
</Page>
