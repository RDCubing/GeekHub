<Page
    x:Class="GeekHub.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GeekHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <x:String x:Key="ChevronGlyph">&#xE26B;</x:String>
        <Storyboard x:Name="FadeInStoryboard">

            <!-- Fade in Title -->
            <DoubleAnimation
            Storyboard.TargetName="TitleText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="FadeInContentStoryboard">

            <!-- Fade in Title -->
            <DoubleAnimation
            Storyboard.TargetName="TitleTextFeed"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

            <!-- Fade in Content (slight delay like Windows 8) -->
            <DoubleAnimation
            Storyboard.TargetName="ContentText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            BeginTime="0:0:0.2"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="SlideInStoryboard">

            <!-- Slide animation -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanelTransform"
            Storyboard.TargetProperty="X"
            From="200" To="0"
            Duration="0:0:1.2"
            EnableDependentAnimation="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>


            <!-- Optional: subtle fade-in -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanel"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="LongFadeInStoryboard">

            <DoubleAnimation
        Storyboard.TargetName="AdImage"
        Storyboard.TargetProperty="Opacity"
        From="0"
        To="1"
        Duration="0:0:2.5"
        EnableDependentAnimation="True"/>

        </Storyboard>


    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">

                <GradientStop Color="#FF141326" Offset="0.0"/>
                <!-- deep dark indigo -->

                <GradientStop Color="#FF2A1833" Offset="0.25"/>
                <!-- muted plum -->

                <GradientStop Color="#FF3E2238" Offset="0.5"/>
                <!-- soft wine -->

                <GradientStop Color="#FF5A2F36" Offset="0.75"/>
                <!-- dim copper -->

                <GradientStop Color="#FF7A4A3A" Offset="1.0"/>
                <!-- toned-down amber -->

            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>
        

        <!-- Header -->
        <TextBlock
        Grid.Row="0"
        Text="GeekHub"
        x:Name="TitleText"
        Margin="50"
        Style="{StaticResource HeaderTextBlockStyle}" />

        <!-- Content Area with horizontal scroll only -->
        <ScrollViewer
    Grid.Row="1"
    ZoomMode="Disabled"
    HorizontalScrollMode="Auto"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollMode="Disabled"
    VerticalScrollBarVisibility="Disabled">

            <StackPanel x:Name="MainPanel" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20" >
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="MainPanelTransform" X="200"/>
                </StackPanel.RenderTransform>
                
                <Grid Width="650" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <TextBlock Grid.Row="0" VerticalAlignment="Center"
               Text="Top 1 App This Season"
               FontSize="36"
                               x:Uid="Top1App"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"/>

                    <!-- HERO BUTTON -->
                    <Button Grid.Row="1"
            Click="FeaturedProject_Click"
            Background="Transparent"
            BorderThickness="0"

            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- IMAGE (TOP, BIGGER) -->
                            <Border Grid.Row="0">
                                <Image Source="{Binding FeaturedProject.LocalDetailImage}"
                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- TEXT (BOTTOM) -->
                            <Border Grid.Row="1"
                    Background="#33000000"
                    Padding="20">

                                <StackPanel VerticalAlignment="Center">

                                    <TextBlock Text="{Binding FeaturedProject.Title}"
                               FontSize="28"
                               FontWeight="Light"
                               Foreground="White"/>

                                    <TextBlock Text="{Binding FeaturedProject.Description}"
                               FontSize="14"
                               Foreground="#CCCCCC"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>

                                </StackPanel>

                            </Border>

                        </Grid>

                    </Button>

                </Grid>
                <!-- Welcome Section -->
                <Grid Width="Auto" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Left"
        Margin="0,0,0,20"
        Click="ProjectsHeader_Click">

                        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

                            <!-- Text -->
                            <TextBlock Text="Projects"
               FontSize="36"
                                       x:Uid="ProjectsSection"
               FontWeight="Light"
               Foreground="White"
               VerticalAlignment="Center"/>

                            <!-- Chevron -->
                            <TextBlock Text="{StaticResource ChevronGlyph}"
               FontFamily="Segoe MDL2 Assets"
               FontSize="20"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>
                        </StackPanel>

                    </Button>

                    <GridView Grid.Row="1"
          x:Name="projectsGridView"
          AutomationProperties.AutomationId="ItemGridView"
          AutomationProperties.Name="Projects Grid"
          Padding="0"
          ItemsSource="{Binding GridProjects}"
          SelectionMode="None"
          IsSwipeEnabled="false"
          IsItemClickEnabled="True"
          ItemClick="ItemView_ItemClick">

                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="180" Height="180">

                                    <Border Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                                        <Image Source="{Binding LocalImage}"
                           Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Bottom"
                            Background="{ThemeResource ListViewItemOverlayBackgroundThemeBrush}">

                                        <TextBlock Text="{Binding Title}"
                               Foreground="{ThemeResource ListViewItemOverlayForegroundThemeBrush}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               FontSize="16"
                               Height="40"
                               Margin="10,0,10,0"/>

                                        <TextBlock Text="{Binding Subtitle}"
                               Foreground="{ThemeResource ListViewItemOverlaySecondaryForegroundThemeBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontSize="10"
                               TextWrapping="NoWrap"
                               Margin="10,0,10,6"/>
                                        <TextBlock Text="{Binding Publisher}"
           Foreground="#99FFFFFF"
           FontSize="11"
           Margin="10,0,10,6"
           TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>

                    </GridView>

                </Grid>
                <!-- Welcome Section -->
                <Grid Width="640" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
               Text="Suggested"
                               x:Uid="SuggestedSection"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"
               TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <!-- Row 1 Border -->
                    <Border Grid.Row="1"
        BorderThickness="2"
        BorderBrush="#66FFFFFF"
        Padding="12"
        Background="Transparent">

                        <StackPanel>

                            <!-- Title inside border -->
                            <TextBlock Text="Welcome to GeekHub!"
           FontSize="28"
                                       x:Uid="SuggestedTitle"
           FontWeight="Light"
           Foreground="White"
           TextWrapping="Wrap"
           Margin="0,0,0,12"
           LineHeight="32"/>

                            <!-- Content inside border -->
                            <TextBlock Text="Welcome to GeekHub, your central place for exploring projects, updates, and creative ideas all in one space. Here you can browse the latest builds, read fresh updates, and discover what's being worked on in real time. GeekHub is designed to keep everything organized and easy to access, so you can quickly jump between projects and stay up to date with new releases and features."
           FontSize="16" Margin="0,0,0,12"
                                       x:Uid="SuggestedContent"
           FontWeight="Light"
           Foreground="#CCFFFFFF"
           TextWrapping="Wrap"
           LineHeight="22"/>
                            <!-- Content inside border -->
                            <TextBlock Text="NanoStore is a lightweight, mini app-store–style system originally developed by Alex and later merged into GeekHub through GitHub repositories. It is inspired by the concept of the Windows 8 Store, but designed in a much smaller and simpler form, focusing on fast browsing, easy installation, and lightweight distribution of apps or tools. Unlike full-scale marketplaces, NanoStore is intended for local or community-based use, making it suitable for small ecosystems where users can quickly access and manage applications without the complexity of a large commercial store."
           FontSize="16"
           FontWeight="Light"
           Foreground="#CCFFFFFF"
           TextWrapping="Wrap"
           LineHeight="22"
                                       x:Uid="SuggestedNano"/>

                        </StackPanel>

                    </Border>



                </Grid>
                <!-- Welcome Section -->
                <Grid Width="500" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Left"
        Margin="0,0,0,20"
        Click="FeedHeader_Click">

                        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

                            <!-- Text -->
                            <TextBlock Text="Latest News"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               VerticalAlignment="Center"
                                       x:Uid="News"/>

                            <!-- Chevron -->
                            <TextBlock Text="{StaticResource ChevronGlyph}"
               FontFamily="Segoe MDL2 Assets"
               FontSize="20"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>
                        </StackPanel>

                    </Button>
                    <!-- Row 1 Border -->
                    <Border Grid.Row="1"
        BorderThickness="2"
        BorderBrush="#66FFFFFF"
        Padding="12"
        Background="Transparent">

                        <StackPanel>

                            <!-- Title inside border -->
                            <TextBlock Text="{Binding CurrentFeedItem.title}" x:Name="TitleTextFeed"
           FontSize="28"
           FontWeight="Light"
           Foreground="White"
           TextWrapping="Wrap"
           Margin="0,0,0,12"
           LineHeight="32"/>

                            <!-- Content inside border -->
                            <TextBlock Text="{Binding CurrentFeedItem.content}" x:Name="ContentText"
           FontSize="16"
           FontWeight="Light"
           Foreground="#CCFFFFFF"
           TextWrapping="Wrap"
           LineHeight="22"/>

                        </StackPanel>

                    </Border>



                </Grid>

            </StackPanel>

        </ScrollViewer>
        <!-- BOTTOM IMAGE ROW -->
        <Grid x:Name="AdImage"
      Background="#FF545454"
      Grid.Row="2"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Center">

            <!-- IMAGE -->
            <Image Source="ms-appx:///Images/650x90.png"
           Stretch="None"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>

            <!-- AD TEXT (BOTTOM LEFT OVERLAY) -->
            <TextBlock Text="ADVERTISEMENT"
               Foreground="White"
               FontSize="12"
               FontWeight="Light"
               Margin="10"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Opacity="0.8"
                       x:Uid="Ad"/>

        </Grid>
    </Grid>
</Page>
