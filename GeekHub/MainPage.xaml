<Page
    x:Class="GeekHub.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GeekHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <x:String x:Key="ChevronGlyph">&#xE26B;</x:String>
        <Storyboard x:Name="FadeInStoryboard">

            <!-- Fade in Title -->
            <DoubleAnimation
            Storyboard.TargetName="TitleText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="FadeInContentStoryboard">

            <!-- Fade in Title -->
            <DoubleAnimation
            Storyboard.TargetName="TitleTextFeed"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

            <!-- Fade in Content (slight delay like Windows 8) -->
            <DoubleAnimation
            Storyboard.TargetName="ContentText"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            BeginTime="0:0:0.2"
            EnableDependentAnimation="True"/>

        </Storyboard>
        <Storyboard x:Name="SlideInStoryboard">

            <!-- Slide animation -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanelTransform"
            Storyboard.TargetProperty="X"
            From="200" To="0"
            Duration="0:0:1.2"
            EnableDependentAnimation="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>


            <!-- Optional: subtle fade-in -->
            <DoubleAnimation
            Storyboard.TargetName="MainPanel"
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.6"
            EnableDependentAnimation="True"/>

        </Storyboard>
        

    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                <GradientStop Color="#661E3C72" Offset="0.0"/>
                <!-- deep blue (transparent) -->
                <GradientStop Color="#662A5298" Offset="0.25"/>
                <!-- blue -->
                <GradientStop Color="#666A11CB" Offset="0.5"/>
                <!-- purple -->
                <GradientStop Color="#662575FC" Offset="0.75"/>
                <!-- bright blue -->
                <GradientStop Color="#6600C6FF" Offset="1.0"/>
                <!-- cyan -->

            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
        Grid.Row="0"
        Text="GeekHub (INDEV)"
        x:Name="TitleText"
        Margin="50"
        Style="{StaticResource HeaderTextBlockStyle}" />

        <!-- Content Area with horizontal scroll only -->
        <ScrollViewer
    Grid.Row="1"
    ZoomMode="Disabled"
    HorizontalScrollMode="Auto"
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollMode="Disabled"
    VerticalScrollBarVisibility="Disabled">

            <StackPanel x:Name="MainPanel" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20" >
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="MainPanelTransform" X="200"/>
                </StackPanel.RenderTransform>
                <!-- Welcome Section -->
                <Grid Width="500" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
               Text="Suggested"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"
               TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <!-- Row 1 Border -->
                    <Border Grid.Row="1"
        BorderThickness="2"
        BorderBrush="#66FFFFFF"
        Padding="12"
        Background="Transparent">

                        <StackPanel>

                            <!-- Title inside border -->
                            <TextBlock Text="Welcome to GeekHub!"
           FontSize="28"
           FontWeight="Light"
           Foreground="White"
           TextWrapping="Wrap"
           Margin="0,0,0,12"
           LineHeight="32"/>

                            <!-- Content inside border -->
                            <TextBlock Text="Welcome to GeekHub, your central place for exploring projects, updates, and creative ideas all in one space. Here you can browse the latest builds, read fresh updates, and discover what's being worked on in real time. GeekHub is designed to keep everything organized and easy to access, so you can quickly jump between projects and stay up to date with new releases and features."
           FontSize="16"
           FontWeight="Light"
           Foreground="#CCFFFFFF"
           TextWrapping="Wrap"
           LineHeight="22"/>

                        </StackPanel>

                    </Border>



                </Grid>
                <!-- Welcome Section -->
                <Grid Width="600" Margin="50,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Left"
        Margin="0,0,0,20"
        Click="ProjectsHeader_Click">

                        <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center">

                            <!-- Text -->
                            <TextBlock Text="Projects"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               VerticalAlignment="Center"/>

                            <!-- Chevron -->
                            <TextBlock Text="{StaticResource ChevronGlyph}"
               FontFamily="Segoe MDL2 Assets"
               FontSize="20"
               Foreground="White"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>
                        </StackPanel>

                    </Button>

                    <GridView Grid.Row="1"
          x:Name="projectsGridView"
          AutomationProperties.AutomationId="ItemGridView"
          AutomationProperties.Name="Projects Grid"
          Padding="0"
          ItemsSource="{Binding GridProjects}"
          SelectionMode="None"
          IsSwipeEnabled="false"
          IsItemClickEnabled="True"
          ItemClick="ItemView_ItemClick">

                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="180" Height="180">

                                    <Border Background="{ThemeResource ListViewItemPlaceholderBackgroundThemeBrush}">
                                        <Image Source="{Binding LocalImage}"
                           Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Bottom"
                            Background="{ThemeResource ListViewItemOverlayBackgroundThemeBrush}">

                                        <TextBlock Text="{Binding Title}"
                               Foreground="{ThemeResource ListViewItemOverlayForegroundThemeBrush}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               FontSize="16"
                               Height="40"
                               Margin="10,0,10,0"/>

                                        <TextBlock Text="{Binding Subtitle}"
                               Foreground="{ThemeResource ListViewItemOverlaySecondaryForegroundThemeBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontSize="10"
                               TextWrapping="NoWrap"
                               Margin="10,0,10,6"/>
                                    </StackPanel>

                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid ItemWidth="190"
                           ItemHeight="190"
                           GroupPadding="0,0,30,0"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>

                    </GridView>

                </Grid>
                <!-- Welcome Section -->
                <Grid Width="500" Margin="0,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0"
               Text="Latest News"
               FontSize="36"
               FontWeight="Light"
               Foreground="White"
               Margin="0,0,0,20"
               TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <!-- Row 1 Border -->
                    <Border Grid.Row="1"
        BorderThickness="2"
        BorderBrush="#66FFFFFF"
        Padding="12"
        Background="Transparent">

                        <StackPanel>

                            <!-- Title inside border -->
                            <TextBlock Text="{Binding CurrentFeedItem.title}" x:Name="TitleTextFeed"
           FontSize="28"
           FontWeight="Light"
           Foreground="White"
           TextWrapping="Wrap"
           Margin="0,0,0,12"
           LineHeight="32"/>

                            <!-- Content inside border -->
                            <TextBlock Text="{Binding CurrentFeedItem.content}" x:Name="ContentText"
           FontSize="16"
           FontWeight="Light"
           Foreground="#CCFFFFFF"
           TextWrapping="Wrap"
           LineHeight="22"/>

                        </StackPanel>

                    </Border>



                </Grid>

            </StackPanel>

        </ScrollViewer>
    </Grid>
</Page>
